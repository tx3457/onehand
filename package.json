{
  "name": "onehand",
  "version": "0.2.0",
  "description": "A recoverable local coding agent with explicit planning, verified completion, and OpenAI/DeepSeek tool use.",
  "type": "module",
  "bin": {
    "onehand": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "demo": "tsx scripts/demo.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.eval.json --noEmit",
    "eval:test": "vitest run tests/eval_*.test.ts",
    "eval:pilot": "tsx eval/cli.ts --mode pilot",
    "eval:full": "tsx eval/cli.ts --mode full"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "openai": "^6.10.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20"
  }
}
